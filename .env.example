# ==============================================================================
# Environment Variables for kanban-todos
# ==============================================================================
# Copy this file to .env.local and fill in values as needed.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ==============================================================================

# ------------------------------------------------------------------------------
# Build / Version Info
# ------------------------------------------------------------------------------
# These are automatically set by the `bun run build` script.
# You typically do NOT need to set these manually.

# Application version (auto-populated from package.json during build)
# Optional - defaults to "1.0.0"
NEXT_PUBLIC_APP_VERSION=4.0.0

# ISO 8601 build timestamp (auto-populated during build)
# Optional - defaults to current time
NEXT_PUBLIC_BUILD_TIME=2026-03-28T12:00:00Z

# Short git commit hash (auto-populated during build)
# Optional - defaults to "dev"
NEXT_PUBLIC_BUILD_HASH=abc1234

# Unix epoch build timestamp (auto-populated during build)
# Optional - defaults to Date.now()
NEXT_PUBLIC_BUILD_TIMESTAMP=1743163200

# ------------------------------------------------------------------------------
# Development
# ------------------------------------------------------------------------------

# Node environment (managed by Next.js, do not set manually)
# NODE_ENV=development

# Enable bundle analyzer (set to "true" to activate @next/bundle-analyzer)
# Optional - defaults to unset (disabled)
# Usage: ANALYZE=true bun run build  (or use `bun run build:analyze`)
# ANALYZE=true

# CI mode flag (used by Playwright config to adjust retries, workers, etc.)
# Optional - automatically set by CI/CD platforms
# CI=true

# ------------------------------------------------------------------------------
# AWS / Deployment
# ------------------------------------------------------------------------------
# These variables are used by the deployment scripts in scripts/.
# AWS credentials should be configured via `aws configure` or standard
# AWS environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, etc.).
# The S3 bucket, CloudFront distribution ID, and domain are configured in
# deploy-config.json and scripts/deploy.sh rather than via env vars.

# Wait for CloudFront cache invalidation to complete before exiting deploy
# Optional - defaults to unset (do not wait)
# Usage: WAIT_FOR_INVALIDATION=true ./scripts/deploy.sh
# WAIT_FOR_INVALIDATION=true

# Override the security headers baseline file path (used by test-security-headers.sh)
# Optional - defaults to docs/security-headers-baseline.json
# BASELINE_FILE=./docs/security-headers-baseline.json
